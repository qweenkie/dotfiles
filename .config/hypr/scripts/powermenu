#!/usr/bin/env bash

entries=(
    "пҖЈ  Lock"
    "пӢө  Logout"
    "пҖһ  Reboot"
    "пҶҶ  Hibernate"
    "оӯ‘  BIOS"
)

case "$1" in
    "") printf '%s\n' "${entries[@]}" ;;
    "пҖЈ  Lock") loginctl lock-session ;;
    "пӢө  Logout") hyprctl dispatch exit ;;
    "пҖһ  Reboot") systemctl reboot ;;
    "пҶҶ  Hibernate") systemctl hibernate ;;
    "оӯ‘  BIOS") systemctl reboot --firmware-setup ;;
esac
